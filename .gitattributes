# Set default behavior to automatically normalize line endings
* text=auto

# Force specific line endings for specific file types
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf

# Binary files (don't touch line endings)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
